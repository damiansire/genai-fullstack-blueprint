{
  "name": "api",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "echo 'Build step skipped. Running native TypeScript.'",
    "dev": "node --import tsx --watch --env-file-if-exists=../../env.example --env-file-if-exists=../../.env src/server.ts",
    "start": "node --import tsx --env-file-if-exists=../../env.example --env-file-if-exists=../../.env src/server.ts",
    "test": "node --env-file-if-exists=../../env.example --env-file-if-exists=../../.env --import tsx --experimental-test-module-mocks --test-force-exit --test \"src/**/*.test.ts\"",
    "mcp:stdio": "node --experimental-strip-types --env-file-if-exists=../../env.example --env-file-if-exists=../../.env src/infrastructure/mcp/mcp-server.ts --stdio",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\""
  },
  "keywords": [],
  "author": "Damian Sire <damiansire@gmail.com>",
  "license": "MIT",
  "description": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/damiansire/GenAI-Scaffold.git",
    "directory": "packages/api"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "multer": "^2.0.2",
    "tsx": "^4.20.6",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.6.2",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1"
  }
}
