{
  "name": "api",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "echo 'Build step skipped. Running native TypeScript.'",
    "dev": "node --experimental-strip-types --watch --env-file=../../env.example src/server.ts",
    "start": "node --experimental-strip-types --permission --allow-fs-read=* --allow-fs-write=/app/data/ --allow-fs-write=data/ --allow-net --allow-worker --env-file=../../env.example src/server.ts",
    "test": "node --env-file=../../env.example --experimental-strip-types --test --experimental-test-coverage src/**/*.test.ts",
    "mcp:stdio": "node --experimental-strip-types --env-file=../../env.example src/infrastructure/mcp/mcp-server.ts --stdio"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "description": "",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@xenova/transformers": "^2.17.2",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "multer": "^2.0.2",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.6.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
