# AI Gateway Environment Configuration
# Copy this file to .env and update with your actual values

# ===========================================
# API Keys Configuration
# ===========================================

# Google Gemini API Key (Required for Image Generation and other Gemini features)
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI API Key (second real provider — packages/api/src/plugins/openai-chat).
# Optional: without it, openai-gpt-4o-mini fails fast with a config error
# instead of calling OpenAI with a placeholder key, and is simply skipped as
# a fallback target (see FALLBACK_MODEL_CHAIN below).
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Ordered, comma-separated fallback chain tried when a provider's circuit
# breaker opens (see InvokeModelUseCase.processWithFallback). Only entries
# actually registered as a plugin are tried; unset defaults to
# "openai-gpt-4o-mini,llama-3.1-8b".
# FALLBACK_MODEL_CHAIN=openai-gpt-4o-mini,llama-3.1-8b

# API Keys for authentication (REQUIRED). Format: KEY:perm1,perm2
# The server fails CLOSED: if no API_KEY_* is set, every request is rejected with
# 401. There is intentionally NO default/fallback key.
API_KEY_1=your-secure-api-key-1:read,write
API_KEY_2=your-secure-api-key-2:read
API_KEY_3=admin-key:read,write,admin

# ===========================================
# Server Configuration
# ===========================================

# Node.js Environment
NODE_ENV=production

# Server Port
PORT=3000

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:4200

# ===========================================
# Observability (OpenTelemetry / OTLP) — OPT-IN
# ===========================================
# Trace + log export is disabled unless an OTLP/HTTP collector endpoint is set.
# Uncomment to export the AsyncLocalStorage span tree to a collector (Jaeger,
# Grafana Tempo, otel-collector). Export degrades gracefully: a missing or flaky
# collector never affects request handling.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=ai-gateway
# Optional per-signal overrides and headers:
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://localhost:4318/v1/logs
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer xyz

# ===========================================
# Client Configuration
# ===========================================

# API URL for the frontend
API_URL=http://localhost:3000/api

# ===========================================
# Docker Configuration
# ===========================================

# Docker Compose Project Name
COMPOSE_PROJECT_NAME=ai-gateway

# ===========================================
# Optional: Additional API Keys
# ===========================================

# Add more API keys as needed
# API_KEY_4=another-key:read
# API_KEY_5=special-key:read,write,admin
